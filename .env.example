# Public site URL for canonical/og:url generation in SEOHead (optional).
# If not set, the site falls back to window.location.origin in the browser.
VITE_SITE_URL=

# Optional Umami analytics (only loaded when both are provided).
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ---- GitHub Pages / base path (optional) ----
# Vite base path (default "/").
# - GitHub Pages project site: "/<repo-name>/"
# - User site / custom domain: "/"
VITE_BASE=/

# Build target selector used by vite.config.ts (optional).
# - (unset): Node/Express build layout -> client to `dist/public`
# - "pages": GitHub Pages static layout -> client to `dist`
VITE_DEPLOY_TARGET=
