{
  "name": "luo-yangwen-portfolio",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "羅揚文（Yang-Wen Luo）作品集網站（Vite + React + TypeScript + Tailwind CSS）",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.4.1"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm -s run format:check",
    "check": "pnpm -s run format:check && pnpm -s run typecheck && pnpm -s run test && pnpm -s run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm -s run check"
  },
  "dependencies": {
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "lucide-react": "^0.453.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "wouter": "^3.7.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/express": "^4.17.21",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.10",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3",
    "vite": "^7.1.9",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "pnpm": {
    "patchedDependencies": {
      "wouter@3.7.1": "patches/wouter@3.7.1.patch"
    },
    "overrides": {
      "tailwindcss>nanoid": "3.3.7"
    }
  }
}
